# ─── Database ───────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to prisma/ directory)
DATABASE_URL=file:./dev.db

# ─── Session Security ───────────────────────────────────────────────────────
# Optional. If omitted, a random secret is auto-generated on first run and
# persisted to `.session-secret` in the project root. That file survives
# restarts so existing sessions remain valid.
#
# Set this explicitly in production to have full control over the secret:
#   openssl rand -hex 32
# SESSION_SECRET=

# ─── WebAuthn (optional overrides) ──────────────────────────────────────────
# In production, set these to your deployment URL to ensure WebAuthn works.
# In development, these are inferred from the request's Origin header.
# NEXT_PUBLIC_ORIGIN=https://netly.example.com
# NEXT_PUBLIC_RPID=netly.example.com

# ─── Node Environment ───────────────────────────────────────────────────────
# NODE_ENV=development
