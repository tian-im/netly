# ─── Database ───────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to prisma/ directory).
# In production (Docker), this defaults to file:/app/data/netly.db
# and points to the mounted volume — no configuration needed.
DATABASE_URL=file:./dev.db

# ─── Session Security ───────────────────────────────────────────────────────
# In development: auto-generated on first run and persisted to
# `.session-secret` in the project root. That file survives restarts
# so existing sessions remain valid.
#
# In production (Docker): auto-generated on first run and persisted to
# `/app/data/.session-secret` inside the mounted volume — zero config.
#
# Set this explicitly ONLY if you need full control over the secret:
#   openssl rand -hex 32
# SESSION_SECRET=
#
# Customize the secret file path (default depends on NODE_ENV):
# SESSION_SECRET_FILE=/custom/path/.session-secret

# ─── WebAuthn (optional overrides) ──────────────────────────────────────────
# In production, set these to your deployment URL to ensure WebAuthn works.
# In development, these are inferred from the request's Origin header.
# NEXT_PUBLIC_ORIGIN=https://netly.example.com
# NEXT_PUBLIC_RPID=netly.example.com

# ─── Node Environment ───────────────────────────────────────────────────────
# NODE_ENV=development

# ─── Model Context Protocol (MCP) ───────────────────────────────────────────
# Optional: Pre-configured MCP access token for AI agent bootstrapping.
# When set (minimum 8 characters), the MCP API accepts this token without a database entry.
# This lets AI assistants connect immediately after Docker install.
# MCP_INITIAL_TOKEN=

